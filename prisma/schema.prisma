generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Reservation {
  id            Int      @id @default(autoincrement())
  studentId     String
  name          String
  phoneNumber   String   @default("")
  passwordHash  String
  roomName      String
  date          String
  startHour     Int
  endHour       Int
  durationHours Int
  createdAt     DateTime @default(now())

  @@index([date, roomName, startHour])
  @@index([studentId, date])
}

model BlockedSlot {
  id        Int      @id @default(autoincrement())
  roomName  String
  weekday   Int
  startHour Int
  endHour   Int
  reason    String
  createdAt DateTime @default(now())

  @@index([weekday, roomName, startHour])
}

model DateBlockedSlot {
  id        Int      @id @default(autoincrement())
  roomName  String
  date      String
  startHour Int
  endHour   Int
  reason    String
  createdAt DateTime @default(now())

  @@index([date, roomName, startHour])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AllowedStudent {
  studentId String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
